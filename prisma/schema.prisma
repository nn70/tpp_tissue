// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 帳號權限宣告
enum Role {
  USER
  EDITOR
  ADMIN
}

// NextAuth Models

// NextAuth.js Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER) // 新增權限欄位
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// APP Models
model Location {
  id              String   @id @default(cuid())
  name            String?
  address         String
  latitude        Float?
  longitude       Float?
  contactName     String?
  contactPhone    String?
  nextContactDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  records      DistributionRecord[]
}

model DistributionRecord {
  id         String   @id @default(cuid())
  locationId String
  itemType   String   @default("面紙") // 新增物品種類欄位，預設面紙
  date       DateTime
  quantity   Int

  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model ItemCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
